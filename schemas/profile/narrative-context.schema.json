{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "narrative-context.schema.json",
  "title": "Narrative Profile — Unit Observables Context",
  "description": "Profile overlay schema constraining unit.observables.context for the narrative profile. Fields reference governed enums from enums.schema.json.",
  "type": "object",
  "properties": {
    "focalizer": {
      "type": "string",
      "minLength": 1,
      "description": "Entity ref of the perceiving character. REQUIRED for unit_type 'scene'."
    },
    "pov": {
      "$ref": "../enums.schema.json#/$defs/pov_type",
      "description": "Point of view type. REQUIRED for unit_type 'scene'."
    },
    "setting": {
      "type": "string",
      "minLength": 1,
      "description": "Entity ref of the location. SHOULD resolve to entity_type 'location'."
    },
    "diegetic_level": {
      "$ref": "../enums.schema.json#/$defs/diegetic_level",
      "description": "Genette diegetic level."
    },
    "time_of_day": {
      "$ref": "../enums.schema.json#/$defs/time_of_day",
      "description": "When the unit occurs."
    },
    "atmosphere": {
      "$ref": "../enums.schema.json#/$defs/tone",
      "description": "Environmental mood (uses tone vocabulary)."
    },
    "spatial_structure": {
      "$ref": "../enums.schema.json#/$defs/spatial_structure",
      "description": "Spatial configuration."
    },
    "narrative_time": {
      "type": "object",
      "description": "Genette temporal architecture.",
      "properties": {
        "order": {
          "$ref": "../enums.schema.json#/$defs/narrative_order",
          "description": "Narrative order."
        },
        "duration_mode": {
          "$ref": "../enums.schema.json#/$defs/duration_mode",
          "description": "Genette duration."
        },
        "frequency": {
          "$ref": "../enums.schema.json#/$defs/frequency",
          "description": "Genette frequency."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
