{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "narrative-story-architecture.schema.json",
  "title": "Narrative Profile — Story Architecture",
  "description": "Schema for the corpus-level story_architecture object. Split into observables/structure/interpretations epistemic layers (v1.1.0).",
  "type": "object",
  "properties": {
    "observables": {
      "type": "object",
      "description": "Facts directly verifiable from the artifact.",
      "properties": {
        "title": {
          "type": "string",
          "description": "Story title."
        },
        "act_count": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of acts."
        },
        "chapter_count": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of chapters."
        },
        "structure_type": {
          "type": "string",
          "description": "Macro structure type (three_act, two_act, kishotenketsu, etc.)."
        },
        "word_count": {
          "type": "integer",
          "minimum": 1,
          "description": "Approximate total word count."
        },
        "has_frame_narrative": {
          "type": "boolean",
          "description": "Whether the story uses frame/embedded narrative structure."
        }
      },
      "additionalProperties": false
    },
    "structure": {
      "type": "object",
      "description": "How the narrative is organized at book level.",
      "properties": {
        "genre": {
          "$ref": "../enums.schema.json#/$defs/genre_type",
          "description": "Primary genre slug."
        },
        "genre_secondary": {
          "$ref": "../enums.schema.json#/$defs/genre_type",
          "description": "Secondary genre (hybridization)."
        },
        "subgenre": {
          "type": "string",
          "description": "Specific subgenre label (e.g. 'cozy mystery', 'space opera')."
        },
        "collision_type": {
          "$ref": "../enums.schema.json#/$defs/collision_type",
          "description": "Structural collision type."
        },
        "inciting_incident": {
          "type": "object",
          "description": "The event that disrupts story equilibrium.",
          "properties": {
            "chapter":       { "type": "integer", "minimum": 1 },
            "incident_type": { "$ref": "../enums.schema.json#/$defs/inciting_incident_type" },
            "description":   { "type": "string" }
          },
          "additionalProperties": false
        },
        "beat_sequence": {
          "type": "array",
          "description": "Macro-arc beat sequence.",
          "items": {
            "type": "object",
            "properties": {
              "beat":        { "$ref": "../enums.schema.json#/$defs/beat_type" },
              "chapter":     { "type": "integer", "minimum": 1 },
              "scene":       { "type": "integer", "minimum": 1 },
              "description": { "type": "string" }
            },
            "required": ["beat"],
            "additionalProperties": false
          }
        },
        "motifs": {
          "type": "array",
          "description": "Story-level recurring motifs.",
          "items": {
            "type": "object",
            "properties": {
              "motif":       { "type": "string", "minLength": 1 },
              "description": { "type": "string" }
            },
            "required": ["motif"],
            "additionalProperties": false
          }
        },
        "actantial_map": {
          "description": "Greimas actantial map.",
          "additionalProperties": true
        },
        "collision_pattern": {
          "$ref": "../enums.schema.json#/$defs/collision_pattern",
          "description": "How the central collision unfolds structurally."
        }
      },
      "additionalProperties": false
    },
    "interpretations": {
      "type": "object",
      "description": "Inferred meaning and analytical claims.",
      "properties": {
        "protagonist_arc": {
          "type": "object",
          "description": "Protagonist arc design.",
          "properties": {
            "arc_direction":       { "$ref": "../enums.schema.json#/$defs/arc_direction" },
            "drive_model":         { "$ref": "../enums.schema.json#/$defs/drive_model" },
            "lie_believed":        { "type": "string" },
            "truth_needed":        { "type": "string" },
            "wound_slug":          { "$ref": "../enums.schema.json#/$defs/wound" },
            "want_need_alignment": { "$ref": "../enums.schema.json#/$defs/want_need_alignment" }
          },
          "additionalProperties": false
        },
        "antagonist": {
          "type": "object",
          "description": "Antagonist design.",
          "properties": {
            "entity_slug":      { "type": "string" },
            "antagonist_type":  { "$ref": "../enums.schema.json#/$defs/antagonist_type" },
            "arc_type":         { "$ref": "../enums.schema.json#/$defs/antagonist_arc_type" },
            "opposition_level": { "$ref": "../enums.schema.json#/$defs/opposition_level" },
            "thematic_mirror":  { "type": "boolean" }
          },
          "additionalProperties": false
        },
        "controlling_idea": {
          "type": "string",
          "description": "Egri / McKee controlling idea."
        },
        "genre_promise": {
          "type": "string",
          "description": "The promise to the reader (genre contract)."
        },
        "power_asymmetry": {
          "$ref": "../enums.schema.json#/$defs/power_asymmetry_type",
          "description": "Which social world has structural advantage."
        },
        "themes": {
          "type": "array",
          "description": "Story-level thematic claims.",
          "items": {
            "type": "object",
            "properties": {
              "theme":           { "type": "string", "minLength": 1 },
              "controlling_idea": { "type": "string" }
            },
            "required": ["theme"],
            "additionalProperties": false
          }
        },
        "transtextuality": {
          "type": "array",
          "description": "Genette transtextual relations to other texts.",
          "items": {
            "type": "object",
            "properties": {
              "type": { "$ref": "../enums.schema.json#/$defs/transtextuality_type" },
              "source_text": { "type": "string" },
              "description": { "type": "string" }
            },
            "required": ["type"],
            "additionalProperties": false
          }
        },
        "comic_mode": {
          "$ref": "../enums.schema.json#/$defs/comic_mode",
          "description": "Bergson/Morreall: dominant comic mode, if applicable."
        },
        "emplotment_type": {
          "$ref": "../enums.schema.json#/$defs/emplotment_type",
          "description": "Hayden White: emplotment type (romance, tragedy, comedy, satire)."
        },
        "mimesis_phase_focus": {
          "$ref": "../enums.schema.json#/$defs/mimesis_phase",
          "description": "Ricoeur: which mimesis phase the story foregrounds."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
