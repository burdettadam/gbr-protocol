{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "narrative-participant-state.schema.json",
  "title": "Narrative Profile — Participant State",
  "description": "Profile overlay schema constraining participant_state entries for the narrative profile.",
  "type": "object",
  "properties": {
    "observables": {
      "type": "object",
      "description": "Observable tactic, body language, and posture.",
      "properties": {
        "tactic": {
          "$ref": "../enums.schema.json#/$defs/tactic",
          "description": "Observable action or strategy used to pursue the objective."
        },
        "body_language": {
          "type": "array",
          "items": { "$ref": "../enums.schema.json#/$defs/body_language" },
          "description": "Observable body language cues."
        },
        "posture": {
          "$ref": "../enums.schema.json#/$defs/posture",
          "description": "Character's physical posture."
        }
      },
      "additionalProperties": false
    },
    "pre_state": {
      "type": "object",
      "description": "State entering this unit. state_type 'emotional' requires a non-empty string value.",
      "properties": {
        "state_type": { "type": "string", "minLength": 1 },
        "value": {}
      },
      "required": ["state_type", "value"],
      "additionalProperties": true
    },
    "post_state": {
      "type": "object",
      "description": "State exiting this unit.",
      "properties": {
        "state_type": { "type": "string", "minLength": 1 },
        "value": {}
      },
      "required": ["state_type", "value"],
      "additionalProperties": true
    },
    "objective": {
      "type": "object",
      "description": "What the participant is trying to achieve in this unit.",
      "properties": {
        "action": { "type": "string", "minLength": 1 },
        "verb": {
          "$ref": "../enums.schema.json#/$defs/objective_verb",
          "description": "Canonical action verb for the objective."
        },
        "object_type": {
          "$ref": "../enums.schema.json#/$defs/objective_object",
          "description": "What type of thing is being acted upon."
        },
        "target": { "type": "string" },
        "constraint": {
          "$ref": "../enums.schema.json#/$defs/objective_constraint",
          "description": "What limits how the objective can be pursued."
        },
        "target_role": {
          "$ref": "../enums.schema.json#/$defs/character_role",
          "description": "Role of the person the objective is directed at."
        }
      },
      "required": ["action"],
      "additionalProperties": false
    },
    "obstacle": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "type": { "$ref": "../enums.schema.json#/$defs/obstacle_type" },
            "source": { "type": "string", "description": "Entity ref or description of obstacle source." },
            "description": { "type": "string" }
          },
          "required": ["description"],
          "additionalProperties": false
        }
      ],
      "description": "What opposes the objective. May be a string or structured object."
    },
    "tactic_shift": {
      "type": "string",
      "description": "How the participant changes tactic during the unit."
    },
    "information_state": {
      "type": "object",
      "description": "What the participant knows and does not know.",
      "properties": {
        "knows": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "subject":   { "type": "string" },
              "predicate": {
                "oneOf": [
                  { "$ref": "../enums.schema.json#/$defs/knowledge_predicate" },
                  { "type": "string" }
                ]
              },
              "about":     { "type": "string" },
              "domain": {
                "$ref": "../enums.schema.json#/$defs/knowledge_domain",
                "description": "What category of knowledge this is."
              },
              "certainty": {
                "oneOf": [
                  { "$ref": "../enums.schema.json#/$defs/knowledge_certainty" },
                  { "type": "null" }
                ]
              }
            },
            "required": ["subject", "predicate", "about"]
          }
        },
        "gaps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "subject":   { "type": "string" },
              "predicate": {
                "oneOf": [
                  { "$ref": "../enums.schema.json#/$defs/knowledge_predicate" },
                  { "type": "string" }
                ]
              },
              "about":     { "type": "string" },
              "certainty": {
                "oneOf": [
                  { "$ref": "../enums.schema.json#/$defs/knowledge_certainty" },
                  { "type": "null" }
                ]
              }
            },
            "required": ["subject", "predicate", "about"]
          }
        },
        "gained": {
          "type": "array",
          "items": { "type": "object" }
        }
      },
      "additionalProperties": false
    },
    "interpretations": {
      "type": "object",
      "description": "Profile-defined interpretive data for this participant state.",
      "properties": {
        "emotion": {
          "$ref": "../enums.schema.json#/$defs/emotion",
          "description": "Dominant emotion at scene entry."
        },
        "arc_beat": {
          "$ref": "../enums.schema.json#/$defs/personal_arc_beat",
          "description": "Character-arc beat active in this scene."
        },
        "emotional_arc": {
          "$ref": "../enums.schema.json#/$defs/emotional_arc",
          "description": "Direction of emotional change through this unit."
        },
        "pov_role": {
          "$ref": "../enums.schema.json#/$defs/pov_role",
          "description": "This participant's relationship to the focalization."
        },
        "social_mask": {
          "$ref": "../enums.schema.json#/$defs/social_mask",
          "description": "Public face presented vs. interior state."
        },
        "wound_triggered": {
          "type": "boolean",
          "description": "Whether the character's core wound is activated in this scene."
        },
        "wound_category": {
          "$ref": "../enums.schema.json#/$defs/wound_category",
          "description": "Which wound category is active, if wound_triggered is true."
        },
        "stakes_personal": {
          "$ref": "../enums.schema.json#/$defs/personal_stakes",
          "description": "What this character personally stands to lose."
        },
        "stakes_relational": {
          "$ref": "../enums.schema.json#/$defs/relational_stakes",
          "description": "What the relationship stands to lose."
        },
        "outcome": {
          "$ref": "../enums.schema.json#/$defs/outcome_type",
          "description": "Whether the character achieved their scene objective."
        },
        "trigger_type": {
          "$ref": "../enums.schema.json#/$defs/trigger_type",
          "description": "What activates the character's wound response."
        },
        "want_from_other": {
          "$ref": "../enums.schema.json#/$defs/want_type",
          "description": "What this participant wants from other characters."
        },
        "underlying_conflict": {
          "$ref": "../enums.schema.json#/$defs/underlying_conflict",
          "description": "The deeper issue beneath surface disagreement."
        },
        "social_circles_active": {
          "type": "array",
          "items": { "$ref": "../enums.schema.json#/$defs/social_circle" },
          "description": "Social circles this character is operating in."
        },
        "want_need_alignment": {
          "$ref": "../enums.schema.json#/$defs/want_need_alignment",
          "description": "Truby want vs. need alignment in this scene."
        },
        "drive_model": {
          "$ref": "../enums.schema.json#/$defs/drive_model",
          "description": "Active motivation model in this scene."
        },
        "gaze_type": {
          "$ref": "../enums.schema.json#/$defs/gaze_type",
          "description": "Mulvey: how this participant is framed by the gaze."
        },
        "trauma_representation": {
          "$ref": "../enums.schema.json#/$defs/trauma_representation_mode",
          "description": "Caruth/Herman: mode of trauma representation."
        },
        "somatic_response": {
          "$ref": "../enums.schema.json#/$defs/somatic_trauma_response",
          "description": "Van der Kolk: somatic trauma response."
        },
        "perception_of_other": {
          "$ref": "../enums.schema.json#/$defs/perception_of_other",
          "description": "How this participant perceives the other characters."
        },
        "stakes_level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "description": "Stakes intensity (1=minimal, 5=existential)."
        },
        "social_role": {
          "$ref": "../enums.schema.json#/$defs/social_role",
          "description": "Character's social role in this scene."
        },
        "actantial_role": {
          "$ref": "../enums.schema.json#/$defs/actantial_role",
          "description": "Greimas: scene-specific actantial role."
        },
        "psychic_distance_shifts": {
          "type": "array",
          "description": "Mid-scene psychic distance changes.",
          "items": {
            "type": "object",
            "properties": {
              "trigger": { "$ref": "../enums.schema.json#/$defs/psychic_distance_trigger" },
              "from_level": { "type": "integer", "minimum": 1, "maximum": 5 },
              "to_level": { "type": "integer", "minimum": 1, "maximum": 5 }
            },
            "required": ["trigger", "from_level", "to_level"],
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": true
    },
    "emotional_state": {
      "type": "object",
      "description": "Compound emotional state shape (for pre_state/post_state values).",
      "properties": {
        "emotion": {
          "$ref": "../enums.schema.json#/$defs/emotion",
          "description": "Primary emotion."
        },
        "intensity": {
          "oneOf": [
            { "$ref": "../enums.schema.json#/$defs/emotion_intensity" },
            { "type": "integer", "minimum": 1, "maximum": 5 }
          ],
          "description": "Emotional intensity (1=subtle, 5=overwhelming). Accepts integer or enum."
        },
        "secondary_emotion": {
          "$ref": "../enums.schema.json#/$defs/emotion",
          "description": "Secondary emotion, if present."
        },
        "masked_emotion": {
          "oneOf": [
            { "$ref": "../enums.schema.json#/$defs/emotion" },
            { "type": "null" }
          ],
          "description": "Hidden emotion being concealed, if any."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
