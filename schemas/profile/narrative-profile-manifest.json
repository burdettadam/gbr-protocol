{
  "profile": "narrative",
  "profile_version": "1.0.0",
  "description": "Manifest of all JSON Schema files for the CAP Narrative Profile Narrative Profile overlay layer.",
  "schemas": {
    "unit.observables.context": "narrative-context.schema.json",
    "unit.structure.grouping": "narrative-grouping.schema.json",
    "unit.interpretations": "narrative-unit-interpretations.schema.json",
    "unit.craft_targets": "narrative-craft-targets.schema.json",
    "participant_state": "narrative-participant-state.schema.json",
    "entity[entity_type=character]": "narrative-entity-character.schema.json",
    "corpus.story_architecture": "narrative-story-architecture.schema.json",
    "relationship.interpretations": "narrative-relationship.schema.json"
  },
  "notes": [
    "All schemas use draft-07.",
    "narrative-context.schema.json and narrative-craft-targets.schema.json were defined in the initial profile release.",
    "narrative-entity-character.schema.json constrains entity.interpretations when entity_type='character'.",
    "narrative-story-architecture.schema.json constrains NarrativeCorpus.story_architecture.",
    "narrative-relationship.schema.json constrains SipRelationship.interpretations when profile='narrative'."
  ]
}
