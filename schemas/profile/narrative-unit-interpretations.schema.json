{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "narrative-unit-interpretations.schema.json",
  "title": "Narrative Profile — Unit Interpretations",
  "description": "Profile overlay schema constraining unit.interpretations for the narrative profile. Applies when profile='narrative'.",
  "type": "object",
  "properties": {
    "pov": {
      "$ref": "../enums.schema.json#/$defs/pov_type",
      "description": "Point of view type."
    },
    "focalization": {
      "$ref": "../enums.schema.json#/$defs/focalization_type",
      "description": "Genette focalization type."
    },
    "consciousness_mode": {
      "$ref": "../enums.schema.json#/$defs/consciousness_mode",
      "description": "Dorrit Cohn consciousness mode."
    },
    "psychic_distance": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Gardner psychic distance level (1=distant narrator, 5=stream of consciousness)."
    },
    "narrator_reliability": {
      "$ref": "../enums.schema.json#/$defs/narrator_reliability_type",
      "description": "Booth narrator reliability."
    },
    "arc_type": {
      "$ref": "../enums.schema.json#/$defs/arc_type",
      "description": "Scene-level arc direction."
    },
    "stakes_domain": {
      "oneOf": [
        { "$ref": "../enums.schema.json#/$defs/personal_stakes" },
        { "type": "array", "items": { "$ref": "../enums.schema.json#/$defs/personal_stakes" } }
      ],
      "description": "Domain of stakes at risk in this unit."
    },
    "canonical_metrics": {
      "type": "object",
      "description": "Structured quality metrics for this unit.",
      "additionalProperties": true
    },
    "canonical_summary": {
      "type": "object",
      "description": "Structured scene goal/obstacle/outcome triplet.",
      "properties": {
        "want":     { "type": "string" },
        "obstacle": { "type": "string" },
        "outcome":  { "type": "string" }
      },
      "additionalProperties": false
    },
    "motif_tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Motif slugs active in this unit."
    },
    "theory_notes": {
      "description": "Free-form or structured literary-theory annotations.",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
