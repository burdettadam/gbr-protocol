{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "narrative-unit-interpretations.schema.json",
  "title": "Narrative Profile — Unit Interpretations",
  "description": "Profile overlay schema constraining unit.interpretations for the narrative profile. Applies when profile='narrative'.",
  "type": "object",
  "properties": {
    "pov": {
      "$ref": "../enums.schema.json#/$defs/pov_type",
      "description": "Point of view type."
    },
    "focalization": {
      "$ref": "../enums.schema.json#/$defs/focalization_type",
      "description": "Genette focalization type."
    },
    "consciousness_mode": {
      "$ref": "../enums.schema.json#/$defs/consciousness_mode",
      "description": "Dorrit Cohn consciousness mode."
    },
    "psychic_distance": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Gardner psychic distance level (1=distant narrator, 5=stream of consciousness)."
    },
    "narrator_reliability": {
      "$ref": "../enums.schema.json#/$defs/narrator_reliability_type",
      "description": "Booth narrator reliability."
    },
    "arc_type": {
      "$ref": "../enums.schema.json#/$defs/arc_type",
      "description": "Scene-level arc direction."
    },
    "stakes_domain": {
      "oneOf": [
        { "$ref": "../enums.schema.json#/$defs/personal_stakes" },
        { "type": "array", "items": { "$ref": "../enums.schema.json#/$defs/personal_stakes" } }
      ],
      "description": "Domain of stakes at risk in this unit."
    },
    "canonical_metrics": {
      "type": "object",
      "description": "Structured quality metrics for this unit.",
      "additionalProperties": true
    },
    "canonical_summary": {
      "type": "object",
      "description": "Structured scene goal/obstacle/outcome triplet.",
      "properties": {
        "want":     { "type": "string" },
        "obstacle": { "type": "string" },
        "outcome":  { "type": "string" }
      },
      "additionalProperties": false
    },
    "motif_tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Motif slugs active in this unit."
    },
    "event_significance": {
      "type": "string",
      "enum": ["kernel", "satellite"],
      "description": "Chatman: kernel (hinge-point opening alternatives) or satellite (elaboration)."
    },
    "pentad_focus": {
      "$ref": "../enums.schema.json#/$defs/pentad_focus",
      "description": "Burke Pentad: which element carries the scene's primary dramatic weight."
    },
    "burke_form": {
      "$ref": "../enums.schema.json#/$defs/burke_form",
      "description": "Burke form taxonomy for this unit."
    },
    "narratee_type": {
      "$ref": "../enums.schema.json#/$defs/narratee_type",
      "description": "Prince narratee theory: explicit, implicit, dramatized, zero_degree."
    },
    "irony_type": {
      "$ref": "../enums.schema.json#/$defs/irony_type",
      "description": "Booth/Hutcheon irony type active in this unit."
    },
    "anti_mimetic_technique": {
      "$ref": "../enums.schema.json#/$defs/anti_mimetic_technique",
      "description": "Richardson: unnatural narratology technique, if any."
    },
    "metafictional_technique": {
      "$ref": "../enums.schema.json#/$defs/metafictional_technique",
      "description": "Waugh/McHale metafictional technique, if any."
    },
    "subtext": {
      "type": "object",
      "description": "Subtext analysis (Hemingway/Grice/Pinter).",
      "properties": {
        "technique": {
          "$ref": "../enums.schema.json#/$defs/subtext_technique",
          "description": "Primary subtext technique."
        },
        "iceberg_category": {
          "$ref": "../enums.schema.json#/$defs/iceberg_category",
          "description": "What is submerged (when technique=iceberg)."
        },
        "maxim_violated": {
          "type": "string",
          "enum": ["quantity", "quality", "relation", "manner"],
          "description": "Grice maxim violated (when technique=gricean_violation)."
        },
        "violation_type": {
          "type": "string",
          "description": "How the maxim is violated."
        }
      },
      "additionalProperties": false
    },
    "psychoanalytic": {
      "type": "object",
      "description": "Psychoanalytic layer (Freud/Lacan/Kristeva).",
      "properties": {
        "freudian_mechanism": {
          "$ref": "../enums.schema.json#/$defs/freudian_mechanism",
          "description": "Dominant Freudian defense or dream mechanism."
        },
        "lacan_register": {
          "$ref": "../enums.schema.json#/$defs/lacan_register",
          "description": "Lacan: real, symbolic, or imaginary register."
        },
        "abject_category": {
          "$ref": "../enums.schema.json#/$defs/abject_category",
          "description": "Kristeva abjection category, if applicable."
        }
      },
      "additionalProperties": false
    },
    "reader_experience": {
      "type": "object",
      "description": "Sternberg/Iser/Ahmed reader-experience analysis.",
      "properties": {
        "primary_effect": {
          "$ref": "../enums.schema.json#/$defs/reader_effect",
          "description": "Sternberg: primary reader experience (curiosity, suspense, surprise)."
        },
        "information_asymmetry": {
          "$ref": "../enums.schema.json#/$defs/information_asymmetry",
          "description": "Who knows more: reader, character, or equal."
        },
        "knowledge_gap_source": {
          "$ref": "../enums.schema.json#/$defs/knowledge_gap_source",
          "description": "Source of the knowledge gap driving suspense/curiosity."
        },
        "textual_affect_type": {
          "$ref": "../enums.schema.json#/$defs/textual_affect_type",
          "description": "Ahmed: type of textual affect economy."
        }
      },
      "additionalProperties": false
    },
    "thematic": {
      "type": "object",
      "description": "Scene-level thematic positioning.",
      "properties": {
        "controlling_idea_position": {
          "$ref": "../enums.schema.json#/$defs/controlling_idea_position",
          "description": "Where this scene falls relative to the controlling idea."
        },
        "thematic_question": {
          "$ref": "../enums.schema.json#/$defs/thematic_question",
          "description": "Which thematic question is being explored."
        }
      },
      "additionalProperties": false
    },
    "motif_deployment": {
      "type": "array",
      "description": "Structured motif tracking (richer than motif_tags).",
      "items": {
        "type": "object",
        "properties": {
          "motif": { "type": "string", "minLength": 1 },
          "category": {
            "$ref": "../enums.schema.json#/$defs/motif_category",
            "description": "Type of recurring element."
          },
          "deployment": {
            "$ref": "../enums.schema.json#/$defs/motif_deployment",
            "description": "How the motif is deployed in this unit."
          },
          "motif_type": {
            "$ref": "../enums.schema.json#/$defs/motif_type",
            "description": "Motif/symbol/leitmotif/objective-correlative."
          }
        },
        "required": ["motif"],
        "additionalProperties": false
      }
    },
    "threads": {
      "type": "object",
      "description": "Narrative thread tracking for continuity.",
      "properties": {
        "active": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "thread": { "type": "string", "minLength": 1 },
              "type": { "$ref": "../enums.schema.json#/$defs/thread_type" },
              "status": { "$ref": "../enums.schema.json#/$defs/thread_status" }
            },
            "required": ["thread"],
            "additionalProperties": false
          },
          "description": "Narrative threads active in this unit."
        },
        "callbacks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "thread": { "type": "string", "minLength": 1 },
              "type": { "$ref": "../enums.schema.json#/$defs/callback_thread_type" },
              "effect": { "$ref": "../enums.schema.json#/$defs/callback_effect" }
            },
            "required": ["thread"],
            "additionalProperties": false
          },
          "description": "Callbacks to previously established threads."
        }
      },
      "additionalProperties": false
    },
    "scene_polarity": {
      "$ref": "../enums.schema.json#/$defs/scene_polarity",
      "description": "McKee: scene-ending polarity shift (positive, negative, ironic)."
    },
    "polarity_transition": {
      "$ref": "../enums.schema.json#/$defs/polarity_transition",
      "description": "Direction of polarity shift through the scene."
    },
    "objective_correlative": {
      "$ref": "../enums.schema.json#/$defs/objective_correlative_type",
      "description": "Eliot: type of objective correlative present."
    },
    "theory_notes": {
      "description": "Free-form or structured literary-theory annotations not covered by formal fields above.",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
