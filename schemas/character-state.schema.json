{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gbr-protocol.dev/schemas/v0/character-state.schema.json",
  "title": "CharacterSceneState",
  "description": "Character state at scene boundaries. v0.2.0: fields organized into observables/structure/interpretations epistemic sections. Canonical field name is 'character' (not character_id/character_ref). Canonical emotion field is 'emotion' (not primary_emotion).",
  "type": "object",
  "required": ["observables"],
  "properties": {
    "observables": {
      "type": "object",
      "description": "Facts directly grounded in the artifact. Fields MUST NOT use the interpreted_value wrapper.",
      "required": ["character", "pov_role"],
      "properties": {
        "character": {
          "type": "string",
          "pattern": "^[a-z0-9_-]+$",
          "description": "Character slug (canonical name; replaces character_id/character_ref)"
        },
        "pov_role": { "$ref": "enums.schema.json#/$defs/pov_role" },
        "posture": { "$ref": "enums.schema.json#/$defs/posture" },
        "body_language": {
          "type": "array",
          "items": { "$ref": "enums.schema.json#/$defs/body_language" }
        },
        "social_circles_active": {
          "type": "array",
          "items": { "$ref": "enums.schema.json#/$defs/social_circle" }
        },
        "fid_markers": {
          "type": "array",
          "items": { "$ref": "enums.schema.json#/$defs/fid_marker" }
        },
        "stress_level": {
          "$ref": "enums.schema.json#/$defs/stress_level",
          "description": "Current stress intensity. Links scene state to the character's entity-level stress_profile tells."
        }
      }
    },

    "structure": {
      "type": "object",
      "description": "How the character's state is organized across the scene boundary.",
      "properties": {
        "objective": {
          "type": "object",
          "properties": {
            "verb": { "$ref": "enums.schema.json#/$defs/objective_verb" },
            "object_type": { "$ref": "enums.schema.json#/$defs/objective_object" },
            "target_role": { "$ref": "enums.schema.json#/$defs/character_role" },
            "constraint": { "$ref": "enums.schema.json#/$defs/objective_constraint" }
          }
        },
        "tactic": {
          "oneOf": [
            { "$ref": "enums.schema.json#/$defs/tactic" },
            { "type": "null" }
          ]
        },
        "tactic_shift": { "$ref": "enums.schema.json#/$defs/tactic" },
        "obstacle": {
          "type": "object",
          "properties": {
            "type": { "$ref": "enums.schema.json#/$defs/obstacle_type" },
            "source_role": { "$ref": "enums.schema.json#/$defs/character_role" }
          }
        },
        "trigger_type": { "$ref": "enums.schema.json#/$defs/trigger_type" },
        "want_outcome": { "$ref": "enums.schema.json#/$defs/outcome_type" },
        "arc_beat": { "$ref": "enums.schema.json#/$defs/personal_arc_beat" },
        "arc_direction": { "$ref": "enums.schema.json#/$defs/arc_direction" },
        "wound_triggered": { "type": "boolean" },
        "knowledge_at_entry": {
          "type": "array",
          "items": { "$ref": "#/$defs/knowledge_item" }
        },
        "knowledge_gaps": {
          "type": "array",
          "items": { "$ref": "#/$defs/knowledge_item" }
        },
        "knowledge_gained": {
          "type": "array",
          "items": { "$ref": "#/$defs/knowledge_item" }
        },
        "relationships": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["target_role"],
            "properties": {
              "target_role": { "$ref": "enums.schema.json#/$defs/character_role" },
              "power_balance": { "$ref": "enums.schema.json#/$defs/power_balance" },
              "power_source": { "$ref": "enums.schema.json#/$defs/power_source" },
              "underlying_conflict": { "$ref": "enums.schema.json#/$defs/underlying_conflict" },
              "wants_from_other": { "$ref": "enums.schema.json#/$defs/want_type" },
              "perceives_other_as": { "$ref": "enums.schema.json#/$defs/perception_of_other" },
              "trigger_type": { "$ref": "enums.schema.json#/$defs/trigger_type" },
              "relationship_turn": { "$ref": "enums.schema.json#/$defs/relationship_turn" }
            }
          }
        },
        "psychic_distance_shifts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["trigger", "from_level", "to_level"],
            "properties": {
              "trigger": { "$ref": "enums.schema.json#/$defs/psychic_distance_trigger" },
              "from_level": { "type": "integer", "minimum": 1, "maximum": 5 },
              "to_level": { "type": "integer", "minimum": 1, "maximum": 5 }
            }
          }
        }
      }
    },

    "interpretations": {
      "type": "object",
      "description": "Inferred meaning. All fields MAY use the interpreted_value wrapper.",
      "properties": {
        "emotional_state_entry": {
          "type": "object",
          "required": ["emotion"],
          "properties": {
            "emotion": { "$ref": "enums.schema.json#/$defs/emotion" },
            "intensity": { "$ref": "enums.schema.json#/$defs/emotion_intensity" },
            "secondary_emotion": { "$ref": "enums.schema.json#/$defs/emotion" },
            "masked": { "type": "boolean" }
          }
        },
        "emotional_state_exit": {
          "type": "object",
          "required": ["emotion"],
          "properties": {
            "emotion": { "$ref": "enums.schema.json#/$defs/emotion" },
            "intensity": { "$ref": "enums.schema.json#/$defs/emotion_intensity" },
            "secondary_emotion": { "$ref": "enums.schema.json#/$defs/emotion" },
            "masked": { "type": "boolean" }
          }
        },
        "emotional_arc": {
          "oneOf": [
            { "$ref": "enums.schema.json#/$defs/emotional_arc" },
            { "$ref": "enums.schema.json#/$defs/interpreted_value" }
          ]
        },
        "emotion": {
          "oneOf": [
            { "$ref": "enums.schema.json#/$defs/emotion" },
            { "$ref": "enums.schema.json#/$defs/interpreted_value" }
          ]
        },
        "masked_emotion": {
          "oneOf": [
            { "$ref": "enums.schema.json#/$defs/emotion" },
            { "type": "null" },
            { "$ref": "enums.schema.json#/$defs/interpreted_value" }
          ]
        },
        "psychic_distance": {
          "oneOf": [
            { "type": "integer", "minimum": 1, "maximum": 5 },
            { "$ref": "enums.schema.json#/$defs/interpreted_value" }
          ],
          "description": "Gardner scale (focal character only)"
        },
        "consciousness_mode": {
          "oneOf": [
            { "$ref": "enums.schema.json#/$defs/consciousness_mode" },
            { "$ref": "enums.schema.json#/$defs/interpreted_value" }
          ]
        },
        "social_mask": {
          "oneOf": [
            { "$ref": "enums.schema.json#/$defs/social_mask" },
            { "$ref": "enums.schema.json#/$defs/interpreted_value" }
          ]
        },
        "social_role": {
          "oneOf": [
            { "$ref": "enums.schema.json#/$defs/social_role" },
            { "$ref": "enums.schema.json#/$defs/interpreted_value" }
          ]
        },
        "want_need_alignment": {
          "oneOf": [
            { "$ref": "enums.schema.json#/$defs/want_need_alignment" },
            { "$ref": "enums.schema.json#/$defs/interpreted_value" }
          ]
        },
        "actantial_role": {
          "oneOf": [
            { "$ref": "enums.schema.json#/$defs/actantial_role" },
            { "$ref": "enums.schema.json#/$defs/interpreted_value" }
          ]
        },
        "wound_category": {
          "oneOf": [
            { "$ref": "enums.schema.json#/$defs/wound_category" },
            { "$ref": "enums.schema.json#/$defs/interpreted_value" }
          ]
        },
        "stakes": {
          "type": "object",
          "properties": {
            "personal": { "$ref": "enums.schema.json#/$defs/personal_stakes" },
            "relational": { "$ref": "enums.schema.json#/$defs/relational_stakes" },
            "level": { "type": "integer", "minimum": 1, "maximum": 5 }
          }
        },
        "arc_type": {
          "oneOf": [
            { "$ref": "enums.schema.json#/$defs/arc_type" },
            { "$ref": "enums.schema.json#/$defs/interpreted_value" }
          ]
        },
        "drive_model": {
          "oneOf": [
            { "$ref": "enums.schema.json#/$defs/drive_model" },
            { "$ref": "enums.schema.json#/$defs/interpreted_value" }
          ]
        }
      }
    }
  },

  "$defs": {
    "knowledge_item": {
      "type": "object",
      "required": ["domain", "predicate"],
      "properties": {
        "domain": { "$ref": "enums.schema.json#/$defs/knowledge_domain" },
        "predicate": { "$ref": "enums.schema.json#/$defs/knowledge_predicate" },
        "about_role": { "$ref": "enums.schema.json#/$defs/character_role" },
        "secondary_role": { "$ref": "enums.schema.json#/$defs/character_role" },
        "certainty": { "$ref": "enums.schema.json#/$defs/knowledge_certainty" }
      }
    }
  }
}
