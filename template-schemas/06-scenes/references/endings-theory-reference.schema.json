{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "grimoire:schemas/06-scenes/references/endings-theory-reference.schema.json",
  "title": "Grimoire · Endings Theory Reference",
  "description": "Extraction schema for endings-theory-reference.md. Fields map to **Label:** fill-ins, tables, and checkbox groups in the template. Mark fields with x-source-required: true when the value should cite a source passage.",
  "type": "object",
  "properties": {
