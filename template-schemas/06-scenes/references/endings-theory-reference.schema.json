      "description": "Metadata about the source text being analyzed (fill in when using this template for book analysis).",
      "x-analysis-only": true
    },
    "property_rows": {
      "type": "array",
      "description": "Table with columns: Property, Definition, Source",
      "items": {
        "type": "object",
        "properties": {
          "property": {
            "type": "string",
            "description": "Property",
            "x-source-required": false
          },
          "definition": {
            "type": "string",
            "description": "Definition",
            "x-source-required": false
          },
          "source": {
            "type": "string",
            "description": "Source",
            "x-source-required": false
          }
        }
      },
      "x-source-required": false
    },
    "work_rows": {
      "type": "array",
      "description": "Table with columns: Work, Key Concept",
      "items": {
        "type": "object",
        "properties": {
          "work": {
            "type": "string",
            "description": "Work",
            "x-source-required": false
          },
          "key_concept": {
            "type": "string",
            "description": "Key Concept",
            "x-source-required": false
          }
        }
      },
      "x-source-required": false
    },
    "_annotations": {
      "$ref": "grimoire:base#/$defs/annotations",
      "description": "Extracted <!-- key:value --> annotation tags."
    }
  },
  "x-grimoire-template": "06-scenes/references/endings-theory-reference.md"
}
