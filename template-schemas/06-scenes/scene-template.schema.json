      "type": "string",
      "description": "Estimated Time to Draft:",
      "x-source-required": false
    },
    "priority": {
      "type": "string",
      "description": "Priority:",
      "x-source-required": false
    },
    "checkboxes_1": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Person vs. Person (interpersonal clash)",
          "Person vs. Self (internal struggle)",
          "Person vs. Environment (physical obstacle)",
          "Person vs. Society (systemic opposition)",
          "Multiple layers (check all that apply)"
        ]
      },
      "uniqueItems": true,
      "description": "Multi-select checkbox group",
      "x-todo": "verify options and whether single/multi-select"
    },
    "checkboxes_2": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "**Full Disaster** — Complete failure; worse off than at scene start",
          "**Partial Disaster** — Gets goal but with unexpected cost/complication",
          "**Dilemma** — Forced to choose between two bad options",
          "**Success with Complication** — Achieves goal but new problem emerges",
          "**Full Success** — Gets goal cleanly (rare; use sparingly)"
        ]
      },
      "uniqueItems": true,
      "description": "Multi-select checkbox group",
      "x-todo": "verify options and whether single/multi-select"
    },
    "checkboxes_3": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Does my POV character have a clear, specific goal?",
          "Is there meaningful opposition to that goal?",
          "Does the scene end differently than it begins?",
          "Does the outcome create a new problem/question that propels the story forward?",
          "Do I know what the next scene's goal is (emerged from this scene's decision)?"
        ]
      },
      "uniqueItems": true,
      "description": "Multi-select checkbox group",
      "x-todo": "verify options and whether single/multi-select"
    },
    "checkboxes_4": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Simple (straightforward action, one location, minimal characters)",
          "Moderate (some complexity, multiple characters, subtext)",
          "Complex (multiple layers, high stakes, intricate choreography)"
        ]
      },
      "uniqueItems": true,
      "description": "Multi-select checkbox group",
      "x-todo": "verify options and whether single/multi-select"
    },
    "checkboxes_5": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Critical (tent-pole scene, can't cut)",
          "Important (significant but could be adjusted)",
          "Supporting (serves story but lower priority)"
        ]
      },
      "uniqueItems": true,
      "description": "Multi-select checkbox group",
      "x-todo": "verify options and whether single/multi-select"
    },
    "_annotations": {
      "$ref": "grimoire:base#/$defs/annotations",
      "description": "Extracted <!-- key:value --> annotation tags."
    }
