    },
    "make_your_own_cliché_watchlist": {
      "type": "string",
      "description": "Make your own cliché watchlist:",
      "x-source-required": false
    },
    "sentence_patterns_i_default_to": {
      "type": "string",
      "description": "Sentence patterns I default to:",
      "x-source-required": false
    },
    "punctuation_quirks": {
      "type": "string",
      "description": "Punctuation quirks:",
      "x-source-required": false
    },
    "crutch_constructions": {
      "type": "string",
      "description": "Crutch constructions:",
      "x-source-required": false
    },
    "_annotations": {
      "$ref": "grimoire:base#/$defs/annotations",
      "description": "Extracted <!-- key:value --> annotation tags."
    }
  },
  "x-grimoire-template": "08-revision/polish/line-edit-checklist.md"
}
