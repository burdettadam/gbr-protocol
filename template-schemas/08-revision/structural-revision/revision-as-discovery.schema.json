{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "grimoire:schemas/08-revision/structural-revision/revision-as-discovery.schema.json",
  "title": "Grimoire · Revision As Discovery",
  "description": "Extraction schema for revision-as-discovery.md. Fields map to **Label:** fill-ins, tables, and checkbox groups in the template. Mark fields with x-source-required: true when the value should cite a source passage.",
  "type": "object",
  "properties": {
    "_source_text": {
      "$ref": "grimoire:base#/$defs/sourceTextMeta",
      "description": "Metadata about the source text being analyzed (fill in when using this template for book analysis).",
      "x-analysis-only": true
    },
    "activity_rows": {
      "type": "array",
      "description": "Table with columns: Activity, Focus, When",
      "items": {
        "type": "object",
        "properties": {
          "activity": {
            "type": "string",
            "description": "Activity",
            "x-source-required": false
          },
          "focus": {
            "type": "string",
            "description": "Focus",
            "x-source-required": false
          },
          "when": {
            "type": "string",
            "description": "When",
            "x-source-required": false
          }
        }
      },
      "x-source-required": false
    },
    "_annotations": {
      "$ref": "grimoire:base#/$defs/annotations",
      "description": "Extracted <!-- key:value --> annotation tags."
    }
  },
  "x-grimoire-template": "08-revision/structural-revision/revision-as-discovery.md"
}
