{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "grimoire:schemas/01-concept/intertextuality-map.schema.json",
  "title": "Grimoire · Intertextuality Map",
  "description": "Extraction schema for intertextuality-map.md. Fields map to **Label:** fill-ins, tables, and checkbox groups in the template. Mark fields with x-source-required: true when the value should cite a source passage.",
  "type": "object",
  "properties": {
    "_source_text": {
      "$ref": "grimoire:base#/$defs/sourceTextMeta",
      "description": "Metadata about the source text being analyzed (fill in when using this template for book analysis).",
      "x-analysis-only": true
    },
    "ratio_rows": {
      "type": "array",
      "description": "Table with columns: Ratio, Definition, Example",
      "items": {
        "type": "object",
        "properties": {
          "ratio": {
            "type": "string",
            "description": "Ratio",
            "x-source-required": false
          },
          "definition": {
            "type": "string",
            "description": "Definition",
            "x-source-required": false
          },
          "example": {
            "type": "string",
            "description": "Example",
            "x-source-required": false
          }
        }
      },
      "x-source-required": false
    },
    "_annotations": {
      "$ref": "grimoire:base#/$defs/annotations",
      "description": "Extracted <!-- key:value --> annotation tags."
    }
  },
  "x-grimoire-template": "01-concept/intertextuality-map.md"
}
