{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "grimoire:schemas/07-drafting/references/sentence-craft-reference.schema.json",
  "title": "Grimoire · Sentence Craft Reference",
  "description": "Extraction schema for sentence-craft-reference.md. Fields map to **Label:** fill-ins, tables, and checkbox groups in the template. Mark fields with x-source-required: true when the value should cite a source passage.",
  "type": "object",
  "properties": {
    "_source_text": {
      "$ref": "grimoire:base#/$defs/sourceTextMeta",
      "description": "Metadata about the source text being analyzed (fill in when using this template for book analysis).",
      "x-analysis-only": true
    },
    "term_rows": {
      "type": "array",
      "description": "Table with columns: Term, Definition, Effect",
      "items": {
        "type": "object",
        "properties": {
          "term": {
            "type": "string",
            "description": "Term",
            "x-source-required": false
          },
          "definition": {
            "type": "string",
            "description": "Definition",
            "x-source-required": false
          },
          "effect": {
            "type": "string",
            "description": "Effect",
            "x-source-required": false
          }
        }
      },
      "x-source-required": false
    },
    "intent_rows": {
      "type": "array",
      "description": "Table with columns: Intent, Technique",
      "items": {
        "type": "object",
        "properties": {
          "intent": {
            "type": "string",
            "description": "Intent",
            "x-source-required": false
          },
          "technique": {
            "type": "string",
            "description": "Technique",
            "x-source-required": false
          }
        }
      },
      "x-source-required": false
    },
    "work_rows": {
      "type": "array",
      "description": "Table with columns: Work, Key Concept",
      "items": {
        "type": "object",
        "properties": {
          "work": {
            "type": "string",
            "description": "Work",
            "x-source-required": false
          },
          "key_concept": {
            "type": "string",
            "description": "Key Concept",
            "x-source-required": false
          }
        }
      },
      "x-source-required": false
    },
    "checkboxes_1": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "**Rhythm checked?** (Read aloud; stumbles = structural problems)"
        ]
      },
      "uniqueItems": true,
      "description": "Multi-select checkbox group",
      "x-todo": "verify options and whether single/multi-select"
    },
    "_annotations": {
      "$ref": "grimoire:base#/$defs/annotations",
      "description": "Extracted <!-- key:value --> annotation tags."
    }
  },
  "x-grimoire-template": "07-drafting/references/sentence-craft-reference.md"
}
