    },
    "checkboxes_4": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "**Not Incompetent** — they win intermediate victories",
          "**Not Late** — their presence is felt by end of Act One (even offscreen)",
          "**Not Unmotivated** — wound + worldview + justification are clear",
          "**Not Overpowered** — they have a specific, character-derived vulnerability",
          "**Not Disconnected** — they mirror the protagonist thematically"
        ]
      },
      "uniqueItems": true,
      "description": "Multi-select checkbox group",
