    "checkboxes_2": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Flat-evil (unchanging; a test for the hero)",
          "Tragic descent (was once good; falls)",
          "Revelation (true nature revealed gradually)",
          "Redemption (begins as antagonist; crosses to ally)",
          "Parallel (shadow arc mirrors protagonist)",
          "Escalation (grows in power/commitment as the story progresses)"
        ]
