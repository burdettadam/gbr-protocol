    },
    "checkboxes_6": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Do major plot points land at appropriate chapter intervals?",
          "Does each act have roughly appropriate number of chapters?",
          "Is the climax positioned near the end (not rushed at 99%)?"
