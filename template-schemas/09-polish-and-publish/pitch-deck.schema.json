{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "grimoire:schemas/09-polish-and-publish/pitch-deck.schema.json",
  "title": "Grimoire · Pitch Deck",
  "description": "Extraction schema for pitch-deck.md. Fields map to **Label:** fill-ins, tables, and checkbox groups in the template. Mark fields with x-source-required: true when the value should cite a source passage.",
  "type": "object",
  "properties": {
    "_source_text": {
      "$ref": "grimoire:base#/$defs/sourceTextMeta",
      "description": "Metadata about the source text being analyzed (fill in when using this template for book analysis).",
      "x-analysis-only": true
    },
    "title_tagline": {
      "type": "string",
      "description": "Title & Tagline:",
      "x-source-required": false
    },
    "overview": {
      "type": "string",
      "description": "Overview:",
      "x-source-required": false
    },
    "comps": {
      "type": "string",
      "description": "Comps:",
      "x-source-required": false
    },
    "bio": {
      "type": "string",
      "description": "Bio:",
      "x-source-required": false
    },
    "_annotations": {
      "$ref": "grimoire:base#/$defs/annotations",
      "description": "Extracted <!-- key:value --> annotation tags."
    }
  },
  "x-grimoire-template": "09-polish-and-publish/pitch-deck.md"
}
