{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "grimoire:schemas/04-world-building/motif-and-symbol-tracker.schema.json",
  "title": "Grimoire · Motif And Symbol Tracker",
  "description": "Extraction schema for motif-and-symbol-tracker.md. Fields map to **Label:** fill-ins, tables, and checkbox groups in the template. Mark fields with x-source-required: true when the value should cite a source passage.",
  "type": "object",
  "properties": {
    "_source_text": {
      "$ref": "grimoire:base#/$defs/sourceTextMeta",
      "description": "Metadata about the source text being analyzed (fill in when using this template for book analysis).",
      "x-analysis-only": true
    },
    "pitfall_rows": {
      "type": "array",
      "description": "Table with columns: Pitfall, Symptom, Fix",
      "items": {
        "type": "object",
        "properties": {
          "pitfall": {
            "type": "string",
            "description": "Pitfall",
            "x-source-required": false
          },
          "symptom": {
            "type": "string",
            "description": "Symptom",
            "x-source-required": false
          },
          "fix": {
            "type": "string",
            "description": "Fix",
            "x-source-required": false
          }
        }
      },
      "x-source-required": false
    },
    "_annotations": {
      "$ref": "grimoire:base#/$defs/annotations",
      "description": "Extracted <!-- key:value --> annotation tags."
    }
  },
  "x-grimoire-template": "04-world-building/motif-and-symbol-tracker.md"
}
